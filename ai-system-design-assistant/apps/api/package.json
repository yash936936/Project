{
  "name": "@asdas/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "worker": "tsx src/workers/pipeline.worker.ts"
  },
  "dependencies": {
    "@asdas/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.36.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "bullmq": "^5.12.0",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "ioredis": "^5.3.2",
    "openai": "^4.65.0",
    "postgres": "^3.4.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.21.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
